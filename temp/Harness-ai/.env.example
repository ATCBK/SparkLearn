# SparkLearn 环境变量模板
# 复制到项目根目录，重命名为 .env，填入真实值。

# ─── Spark (讯飞星火大模型) ────────────────────────────────────────────────────
SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=
SPARK_MODEL=lite
SPARK_API_URL=wss://maas-api.cn-huabei-1.xf-yun.com/v1.1/chat
SPARK_USE_BRIDGE=true

# ─── Coze (资源生成) ───────────────────────────────────────────────────────────
COZE_API_TOKEN=
COZE_BASE_URL=https://api.coze.cn
COZE_API_PATH_CHAT=/v3/chat
COZE_DEFAULT_USER_ID=single_user
COZE_BOT_ID_RESOURCE_DEFAULT=
COZE_BOT_ID_RESOURCE_DOCUMENT=
COZE_BOT_ID_RESOURCE_MINDMAP=
COZE_BOT_ID_RESOURCE_QUIZ=
COZE_BOT_ID_RESOURCE_READING=
COZE_BOT_ID_RESOURCE_CODE=

# ─── iFlytek 智文 PPT ─────────────────────────────────────────────────────────
XFYUN_ZW_APP_ID=
XFYUN_ZW_BASE_URL=https://zwapi.xfyun.cn
XFYUN_ZW_API_SECRET=
XFYUN_ZW_TIMEOUT_SEC=240
XFYUN_ZW_PPT_AUTHOR=SparkLearn

# ─── iFlytek TTS (视频语音合成) ────────────────────────────────────────────────
XF_TTS_APP_ID=
XF_TTS_API_KEY=
XF_TTS_API_SECRET=
XF_TTS_BASE_URL=wss://tts-api.xfyun.cn/v2/tts
XF_TTS_DEFAULT_VOICE=xiaoyan
XF_TTS_TIMEOUT_MS=15000
XF_TTS_TEXT_LIMIT=1000
XF_TTS_MAX_CONCURRENCY=2

# ─── Video AI (OpenAI 兼容接口，视频脚本生成) ─────────────────────────────────
# 必填: VIDEO_AI_API_KEY, VIDEO_AI_MODEL
# 示例使用 DeepSeek:  VIDEO_AI_BASE_URL=https://api.deepseek.com/v1  VIDEO_AI_MODEL=deepseek-chat
# 示例使用 OpenAI:    VIDEO_AI_BASE_URL=https://api.openai.com/v1    VIDEO_AI_MODEL=gpt-4o
VIDEO_AI_ENABLED=true
VIDEO_AI_PROVIDER=openai_compatible
VIDEO_AI_BASE_URL=https://api.openai.com/v1
VIDEO_AI_CHAT_PATH=/chat/completions
VIDEO_AI_API_KEY=
VIDEO_AI_MODEL=
VIDEO_AI_AGENT_URL=
VIDEO_AI_AGENT_TOKEN=
VIDEO_AI_TIMEOUT_SEC=45
VIDEO_AI_MAX_TOKENS=4096
VIDEO_AI_TEMPERATURE=0.7
VIDEO_AI_FALLBACK_ENABLED=false

# ─── Agent Browser ─────────────────────────────────────────────────────────────
AGENT_BROWSER_HEADLESS=false
AGENT_BROWSER_SLOW_MO=800

# ─── App ────────────────────────────────────────────────────────────────────────
APP_NAME=SparkLearn API
APP_VERSION=1.0.0
DEBUG=true
USE_MOCK_DATA=true
CORS_ORIGIN=http://localhost:3000

{
  "providers": {
    "deepseek": {
      "apiKey": "${DEEPSEEK_API_KEY}",
      "apiBase": "https://api.deepseek.com"
    }
  },
  "agents": {
    "defaults": {
      "provider": "deepseek",
      "model": "deepseek-chat",
      "workspace": "./nanobot-workspace",
      "timezone": "Asia/Shanghai",
      "maxIterations": 6,
      "maxConcurrentSubagents": 1,
      "restrictToWorkspace": true
    }
  },
  "api": {
    "host": "127.0.0.1",
    "port": 8900,
    "timeout": 120
  },
  "tools": {
    "restrictToWorkspace": true,
    "web": {
      "enabled": true,
      "search": {
        "provider": "tavily",
        "apiKey": "${TAVILY_API_KEY}"
      }
    }
  }
}
